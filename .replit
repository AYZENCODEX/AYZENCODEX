modules = ["nodejs-20", "web", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["sh", "-c", "PORT=8080 DATABASE_URL=postgresql://postgres:password@helium:5432/heliumdb pnpm --filter @workspace/api-server run start"]
build = ["sh", "-c", "pnpm --filter @workspace/api-server run build && NODE_ENV=production pnpm --filter @workspace/ayzen run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow]]
name = "Frontend"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/ayzen && PORT=5000 AYZEN_API_PORT=8000 node_modules/.bin/vite --config vite.config.ts --host 0.0.0.0 --port 5000"
waitForPort = 5000

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && PORT=8000 node --enable-source-maps ./dist/index.mjs"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 8083
externalPort = 3003

[[ports]]
localPort = 23325
externalPort = 3000

[userenv]

[userenv.shared]
FIREBASE_PROJECT_ID = "ayzenworkspacex01"
AYZEN_API_PORT = "8000"
AYZEN_FRONTEND_PORT = "8080"
