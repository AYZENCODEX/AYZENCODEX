modules = ["nodejs-20", "web", "postgresql-16", "python-base-3.13"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["sh", "-c", "PORT=8080 DATABASE_URL=postgresql://postgres:password@helium:5432/heliumdb pnpm --filter @workspace/api-server run start"]
build = ["sh", "-c", "pnpm --filter @workspace/api-server run build && NODE_ENV=production pnpm --filter @workspace/ayzen run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/ayzen: web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/api-server: API Server"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_openai_ai_integrations:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[[ports]]
localPort = 8083
externalPort = 3003

[[ports]]
localPort = 23325
externalPort = 3000

[userenv]

[userenv.shared]
FIREBASE_PROJECT_ID = "ayzenworkspacex01"
AYZEN_API_PORT = "8080"
AYZEN_FRONTEND_PORT = "8080"
NODE_ENV = "development"
PORT = "23325"
LOG_LEVEL = "info"
